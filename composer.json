{
    "name": "phalanx/sentinel",
    "description": "AI agent watcher system for real-time code review",
    "type": "project",
    "license": "MIT",
    "repositories": [
        { "type": "vcs", "url": "https://github.com/havy-tech/daemonai-php-sdk" }
    ],
    "require": {
        "php": "^8.4",
        "phalanx/core": "^0.3",
        "phalanx/ai": "^0.3",
        "phalanx/console": "^0.3",
        "phalanx/stream": "^0.3",
        "daemonai/sdk": "dev-main",
        "react/child-process": "^0.6",
        "symfony/runtime": "^7.2",
        "symfony/dotenv": "^7.2",
        "tempest/highlight": "^2.17"
    },
    "bin": ["bin/sentinel.php"],
    "autoload": {
        "psr-4": {
            "Phalanx\\Sentinel\\": "src/Sentinel/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "runtime": {
            "class": "Phalanx\\Sentinel\\ConsoleRuntime"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}

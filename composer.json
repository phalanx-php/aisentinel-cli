{
    "name": "phalanx/sentinel",
    "description": "AI agent watcher system for real-time code review",
    "type": "project",
    "license": "MIT",
    "repositories": [
        { "type": "path", "url": "../phalanx/packages/phalanx-core",    "options": { "symlink": true } },
        { "type": "path", "url": "../phalanx/packages/phalanx-console",  "options": { "symlink": true } },
        { "type": "path", "url": "../phalanx/packages/phalanx-stream",   "options": { "symlink": true } },
        { "type": "path", "url": "../phalanx/packages/phalanx-ai",       "options": { "symlink": true } },
        { "type": "path", "url": "../phalanx/packages/phalanx-terminal", "options": { "symlink": true } },
        { "type": "vcs",  "url": "https://github.com/havy-tech/daemon8-php-sdk" }
    ],
    "require": {
        "php": "^8.4",
        "phalanx/core": "*",
        "phalanx/ai": "*",
        "phalanx/console": "*",
        "phalanx/stream": "*",
        "phalanx/terminal": "*",
        "havy-tech/daemon8": "dev-main",
        "react/child-process": "^0.6",
        "symfony/runtime": "^7.2",
        "symfony/dotenv": "^7.2",
        "tempest/highlight": "^2.17"
    },
    "bin": ["bin/sentinel.php"],
    "autoload": {
        "psr-4": {
            "Phalanx\\Sentinel\\": "src/Sentinel/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "runtime": {
            "class": "Phalanx\\Sentinel\\ConsoleRuntime"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
